# Copy this file to .env.test and fill in your values.
# cp .env.test.template .env.test

# Your Rhombus API key — generate one at https://console.rhombus.com/settings/api-management
RHOMBUS_API_KEY=your_api_key_here

# Rhombus API hostname (default is production; override for staging/dev — no https:// prefix)
RHOMBUS_API_SERVER=api.rhombus.com

# UUID of a camera in your org to use in integration tests
CAMERA_UUID=your_camera_uuid_here

# Set to "true" to enable heavy tests (e.g. sampling many live cameras).
# These are skipped by default as they are slow and make many API calls.
TEST_HEAVY=false

# --- Amplitude analytics (optional) ---
# Analytics are OFF unless AMPLITUDE_API_KEY is set. When set, the server emits
# a "MCP Tool Called" event per tool invocation (tool name, success, duration,
# arg keys — never arg values), tagged with the caller's user/org identity.
# AMPLITUDE_API_KEY=your_amplitude_api_key_here
# AMPLITUDE_SERVER_ZONE=US   # US (default) or EU
